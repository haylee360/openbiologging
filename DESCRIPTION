Package: openbiologging
Type: Package
Title: Dataset of Open Data Practices in Biologging Research
Version: 0.1.0
Authors@R: c(
    person(
      "Max", "Czapanskiy",
      email = "maxczap@ucsb.edu",
      role = c("aut", "cre")
    )
    person(
      "Haylee", "Oyler",
      email = "hayleeoyler360@gmail.com",
